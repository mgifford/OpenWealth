{
  "name": "openwealth",
  "version": "0.1.0",
  "private": true,
  "description": "Open, privacy-first Canadian scenario planning app.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "node scripts/build.mjs",
    "data:refresh": "node scripts/data-refresh/refresh-public-data.mjs",
    "batch:scenarios": "node scripts/batch/run-scenarios.mjs",
    "release:package": "node scripts/release/package-release.mjs",
    "privacy:guard": "node scripts/privacy/artifact-guard.js dist",
    "lint": "node scripts/lint.mjs",
    "test": "npm run test:unit",
    "test:schema": "node --test tests/schema/**/*.test.mjs",
    "test:integration": "node --test tests/integration/**/*.test.mjs",
    "test:unit": "node --test tests/unit/**/*.test.mjs",
    "test:regression": "node --test tests/regression/**/*.test.mjs"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "yaml": "^2.8.2"
  }
}

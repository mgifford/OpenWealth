{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openwealth.dev/schemas/account.schema.json",
  "title": "Account",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "account_id",
    "account_type",
    "ownership",
    "currency",
    "current_balance",
    "last_updated"
  ],
  "properties": {
    "account_id": { "type": "string", "minLength": 1 },
    "account_type": {
      "type": "string",
      "enum": [
        "tfsa",
        "rrsp",
        "fhsa",
        "resp",
        "non_registered",
        "chequing_savings",
        "dc_pension",
        "db_pension_placeholder",
        "mortgage",
        "other_debt"
      ]
    },
    "ownership": { "type": "string", "enum": ["individual", "joint", "household"] },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "default": "CAD" },
    "current_balance": { "type": "number" },
    "contribution_room": { "type": "number" },
    "annual_contribution": { "type": "number" },
    "annual_withdrawal": { "type": "number" },
    "adjusted_cost_base": { "type": "number" },
    "institution": { "type": "string" },
    "notes": { "type": "string" },
    "import_source": { "type": "string" },
    "last_updated": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}" },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "user_verified": { "type": "boolean" }
  }
}

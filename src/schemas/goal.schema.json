{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openwealth.dev/schemas/goal.schema.json",
  "title": "Goal",
  "type": "object",
  "additionalProperties": false,
  "required": ["goal_id", "goal_type", "target_amount", "target_date"],
  "properties": {
    "goal_id": { "type": "string", "minLength": 1 },
    "goal_type": {
      "type": "string",
      "enum": ["retirement_income", "education", "home_purchase", "debt_repayment", "emergency_fund", "other"]
    },
    "target_amount": { "type": "number", "minimum": 0 },
    "target_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
    "notes": { "type": "string" }
  }
}

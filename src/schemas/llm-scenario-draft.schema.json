{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openwealth.dev/schemas/llm-scenario-draft.schema.json",
  "title": "LlmScenarioDraft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_draft",
    "missing_inputs",
    "assumptions",
    "confidence_notes",
    "disclaimer"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "scenario_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "retirement_age", "cpp_start_age", "oas_start_age", "withdrawal_strategy"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "retirement_age": { "type": "integer", "minimum": 40, "maximum": 75 },
        "cpp_start_age": { "type": "integer", "minimum": 60, "maximum": 70 },
        "oas_start_age": { "type": "integer", "minimum": 65, "maximum": 75 },
        "withdrawal_strategy": { "type": "string", "enum": ["blended", "tfsa_first", "rrsp_first"] },
        "annual_spending": { "type": "number", "minimum": 0 }
      }
    },
    "missing_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "reason"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "confidence_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "confidence", "note"],
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "disclaimer": { "type": "string", "minLength": 1 }
  }
}

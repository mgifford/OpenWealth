{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openwealth.dev/schemas/provenance.schema.json",
  "title": "ImportProvenanceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "field_path",
    "source_file",
    "imported_at",
    "confidence",
    "approved_by_user"
  ],
  "properties": {
    "field_path": { "type": "string", "pattern": "^/" },
    "old_value": {},
    "new_value": {},
    "source_file": { "type": "string", "minLength": 1 },
    "imported_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "approved_by_user": { "type": "boolean" }
  }
}

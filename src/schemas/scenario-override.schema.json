{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openwealth.dev/schemas/scenario-override.schema.json",
  "title": "ScenarioOverride",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scenario_id", "name", "base_household_id", "overrides", "created_at"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "base_household_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "created_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
    "overrides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "op"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^/(assumptions|people|accounts|liabilities|income_sources|goals|sustainability_preferences)(/.*)?$"
          },
          "op": { "type": "string", "enum": ["add", "replace", "remove"] },
          "value": {}
        },
        "allOf": [
          {
            "if": { "properties": { "op": { "const": "remove" } }, "required": ["op"] },
            "then": true,
            "else": { "required": ["value"] }
          }
        ]
      }
    }
  }
}

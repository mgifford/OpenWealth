{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openwealth.dev/schemas/snapshot.schema.json",
  "title": "Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["snapshot_id", "household_id", "captured_at", "reason", "state_hash", "bundle_refs"],
  "properties": {
    "snapshot_id": { "type": "string", "minLength": 1 },
    "household_id": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
    "reason": { "type": "string", "minLength": 1 },
    "state_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{16,}$" },
    "bundle_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
